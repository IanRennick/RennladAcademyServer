<%= form_with(model: [question, comment]) do |f| %>
  <div class="form-control">
    <%# Pass commentable type to controller %>
    <%= hidden_field_tag :commentable_type, commentable_type %>

    <%# Body Input %>
    <%= f.rich_text_area :body %>

    <%# Submit Button %>
    <%= f.submit submit_label, class: "btn btn-primary mt-1"  %>
  </div>
<% end %>