<%# app/views/questions/index.html.erb %>
<%# =========================================================================
    MASTER CURRICULUM GRAMMAR PUZZLE REGISTRY
    - Houses total question inventories, data topology matrices, and Ransack listings
    - Built using crisp dark theme styling parameters with full text contrast safety
   ========================================================================= %>
<div class="container-fluid min-vh-100 bg-dark text-light p-4" style="background-color: #0f1115 !important;">
  
  <%# Master Page Header Dashboard Status Ribbon %>
  <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25 font-sans">
    <div>
      <h2 class="fw-bold text-white mb-0 tracking-wide">📚 Curriculum Puzzle Library</h2>
      <p class="text-white-50 small mb-0 mt-1">Manage polymorphic grammar puzzles, view stock boundaries, and trace sorting parameters</p>
    </div>
    <% if respond_to?(:new_question_path) %>
      <%= link_to "+ Create New Puzzle", new_question_path, class: "btn btn-sm btn-success font-monospace fw-bold px-3 py-2 shadow-sm" %>
    <% end %>
  </div>

  <%# PARTIAL 1: Renders Content-Balance & Topology Inventory Stocks Dashboard %>
  <%= render "questions/analytics_dashboard" %>

  <%# =======================================================================
      WORKSPACE CONTROL MATRIX: LAYOUT ROW CONTAINERS
     ======================================================================= %>
  <div class="row font-sans">
    
    <%# COLUMN A: Left Sticky Filter Sidebar Matrix Partial Hook %>
    <div class="col-lg-3 col-md-4 mb-4">
      <%= render "questions/filter_sidebar" %>
    </div>

    <%# COLUMN B: Right Dynamic Adaptive Data Grid Table %>
    <div class="col-lg-9 col-md-8">
      <div class="card bg-black bg-opacity-30 border border-secondary border-opacity-20 p-0 overflow-hidden shadow-lg rounded">
        
        <%# Determine which specialized column layout config to mount dynamically %>
        <% current_kind_filter = params.dig(:q, :kind_eq) %>

        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; font-size: 0.88rem;">
            <thead>
              <tr class="text-white-50 border-bottom border-secondary border-opacity-20" style="font-size: 0.78rem; background-color: rgba(0,0,0,0.15);">
                <th scope="col" class="ps-3 py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 70px;"><%= sort_link(@query, :id, "ID", class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 110px;"><%= sort_link(@query, :subtype, "Subtype", class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Question Context</th>
                
                <%# DYNAMIC COLUMNS BOUND BASED ON THE CHOSEN PUZZLE KIND FILTER %>
                <% case current_kind_filter %>
                <% when "0" # multiple_choice %>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Options Array Context</th>
                <% when "2" # word_formation %>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Base Keyword Clue</th>
                <% when "3" # sentence_cloze %>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Base Keyword Clue</th>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Prompt Sentence Target</th>
                <% else %>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Clues & Settings Parameters</th>
                <% end %>

                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 120px;">First Answer</th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 80px;">Level</th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 100px;"><%= sort_link(@query, :rating, "Rating", class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider" style="width: 90px;">Success</th>
                <th scope="col" class="text-end pe-4 py-2.5 Richmond-Controls fw-semibold text-uppercase tracking-wider" style="width: 80px;">Shortcut</th>
              </tr>
            </thead>
            
            <tbody>
              <% if @questions.any? %>
                <% @questions.each do |question| %>
                  <%# ✅ DYNAMIC DATA ROW INJECTION %>
                  <%= render "question_row", question: question, current_filter: current_kind_filter %>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="9" class="text-center text-white-50 py-5 font-monospace small">
                    ⚠️ No curriculum questions matched your current filter parameter combinations.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# COMPONENT 3: Pagy Pagination Selector Footer Control Bar %>
        <% if defined?(@pagy) && @pagy && @pagy.pages > 1 %>
          <div class="card-footer bg-black bg-opacity-40 border-top border-secondary border-opacity-25 p-3 d-flex justify-content-center shadow-inner">
            <%== pagy_bootstrap_nav(@pagy) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>