<div class="container">
    <%# Links %>
    <%= render "questions/links" %>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <%# Question main Heading %>
                <th scope="col">Question</th>

                <%# Answer Heading %>
                <th scope="col">Answer</th>

                <%# Keyword Heading %>
                <th scope="col">Keyword</th>

                <%# Prompt Heading %>
                <th scope="col">Prompt</th>

                <%# Shared Headings %>
                <%= render "questions/tables/shared_table_headings" %>
            </tr>
        </thead>

        <tbody>
            <% @questions.each do |question| %>
                <tr>
                    <%# Question main %>
                    <td><%= question.main %></td>

                    <%# Answer %>
                    <td><%= question.answer %></td>

                    <%# Keyword %>
                    <td><%= question.keyword %></td>

                    <%# Prompt %>
                    <td><%= question.prompt %></td>

                    <%# Question ID %>
                    <td><%= link_to question.id, question_path(question) %></td>

                    <%# Amount of attempts %>
                    <td><%= question.attempted %></td>

                    <%# Amount of correct answers %>
                    <td><%= question.correct %></td>

                    <%# Amount of comments %>
                    <td><%= pluralize(question.comments.size, "Comment") %></td>
                </tr>
            <% end %>
        </tbody>
    </table>
</div>