<div class="container">
  <%# Question %>
  <%= render @question %>

  <div>
    <%# Link back to all questions %>
    <%= link_to "Back to questions", questions_path %>
  </div>

  <%# Common wrong answers %>
  <h3>Common Wrong Submissions</h3>
  <ul>
    <% @question.wrong_answers.order(count: :desc).limit(5).each do |wa| %>
      <li><strong>"<%= wa.answer_text %>"</strong> — Submitted <%= pluralize(wa.count, "time") %></li>
    <% end %>
  </ul>
</div>

<div class="container">
  <%# Render the central thread creation form %>
  <%= render "shared/comment_form", commentable: @question, comment: @question.comments.build, submit_label: "Post Comment" %>

  <%# Loop and print out the root comment tree threads %>
  <% @comments.each do |comment| %>
    <%= render "shared/comment", commentable: @question, comment: comment %>
  <% end %>
</div>