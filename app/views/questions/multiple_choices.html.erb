<div class="container">
    <%# Links %>
    <%= render "questions/links" %>


    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <%# Question main Heading %>
                <th scope="col">Question</th>

                <%# Answer Heading %>
                <th scope="col">Answer</th>

                <%# Option A Heading %>
                <th scope="col">Option A</th>

                <%# Option B Heading %>
                <th scope="col">Option B</th>

                <%# Option C Heading %>
                <th scope="col">Option C</th>

                <%# Option D Heading %>
                <th scope="col">Option D</th>

                <%# Shared Headings %>
                <%= render "questions/tables/shared_table_headings" %>
            </tr>
        </thead>

        <tbody>
            <% @questions.each do |question| %>
                <tr>                   
                    <%# Question main %>
                    <td><%= question.main %></td>

                    <%# Answer %>
                    <td><%= question.answer %></td>

                    <%# Option A %>
                    <td><%= question.a %></td>

                    <%# Option B %>
                    <td><%= question.b %></td>

                    <%# Option C %>
                    <td><%= question.c %></td>

                    <%# Option D %>
                    <td><%= question.d %></td>

                    <%# Question ID %>
                    <td><%= link_to question.id, question_path(question) %></td>

                    <%# Amount of attempts %>
                    <td><%= question.attempted %></td>

                    <%# Amount of correct answers %>
                    <td><%= question.correct %></td>

                    <%# Amount of comments %>
                    <td><%= pluralize(question.comments.size, "Comment") %></td>
                </tr>
            <% end %>
        </tbody>
    </table>
</div>
