<div class="container">
    <%# Links %>
    <%= render "questions/links" %>


    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <%# Common Headings %>
                <%= render "questions/tables/common_table_headings" %>

                <%# Option A Heading %>
                <th scope="col">A</th>

                <%# Option B Heading %>
                <th scope="col">B</th>

                <%# Option C Heading %>
                <th scope="col">C</th>

                <%# Option D Heading %>
                <th scope="col">D</th>

                <%# Shared Headings %>
                <%= render "questions/tables/shared_table_headings" %>
            </tr>
        </thead>

        <tbody>
            <% @questions.each do |question| %>
                <tr>                   
                    <%# Common Bodies %>
                    <%= render partial: "questions/tables/common_table_bodies", object: question %>

                    <%# Safe array index lookups that output a blank string if an option doesn't exist %>
                    <td><%= question.options&.[](0) %></td>
                    <td><%= question.options&.[](1) %></td>
                    <td><%= question.options&.[](2) %></td>
                    <td><%= question.options&.[](3) %></td>


                    <%# Shared Bodies %>
                    <%= render partial: "questions/tables/shared_table_bodies", object: question %>
                </tr>
            <% end %>
        </tbody>
    </table>
</div>
