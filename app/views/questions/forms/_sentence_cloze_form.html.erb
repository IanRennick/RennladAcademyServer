<%= form_with(model: question) do |form| %>
  <%# Throw any errors %>
  <% if question.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(question.errors.count, "error") %> prohibited this question from being saved:</h2>

      <ul>
        <% question.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Levels Input %>
  <div style="margin-top: 15px; margin-bottom: 15px;">
    <%= form.label :level_id, "Target Language Level", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
    <%= form.collection_select :level_id, Level.order(:name), :id, :name, { include_blank: "No Level Assigned" }, { style: "width: 100%; max-width: 400px; padding: 6px;" } %>
  </div>

  <%# Subtypes Input %>
  <div>
    <%= form.label :subtype, "Sentence Cloze Category", style: "display: block;" %>
    <%= form.select :subtype, 
      Question::SUBTYPES_BY_KIND["sentence_cloze"].map { |s| [s.to_s.titleize, s] }, 
      include_blank: "Select Subtype" 
    %>
  </div>

  <%# Question main input %>
  <div>
    <%= form.label :main, style: "display: block" %>
    <%= form.text_field :main %>
  </div>

  <%# Dynamic Answers Section %>
  <div style="margin-bottom: 20px;">
    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Accepted Answers</label>
    
    <div id="answers-container">
      <%# Render up to 5 inputs. Loop ensures existing answers populate on edit %>
      <% 5.times do |i| %>
        <% current_value = question.answers&.[](i) %>
        <div class="answer-field-group" style="margin-bottom: 8px; <%= 'display: none;' if i > 0 && current_value.blank? %>" data-index="<%= i %>">
          <%= text_field_tag "question[answers][]", current_value, placeholder: "Answer #{i + 1}", style: "width: 80%; max-width: 400px;" %>
        </div>
      <% end %>
    </div>

    <%# Simple button to show the next hidden answer field %>
    <button type="button" id="add-answer-btn" style="margin-top: 5px; font-size: 12px; cursor: pointer;">
      + Add Another Valid Answer
    </button>
  </div>

  <%# Keyword Input %>
  <div>
    <%= form.label :keyword, style: "display: block" %>
    <%= form.text_field :keyword %>
  </div>

  <%# Prompt Input %>
  <div>
    <%= form.label :prompt, style: "display: block" %>
    <%= form.text_field :prompt %>
  </div>

  <div style="margin-top: 15px; margin-bottom: 15px;">
    <%= form.label :tag_list, "Tags (Separated by commas)", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
    <%= form.text_field :tag_list, 
                        value: question.tag_list, 
                        placeholder: "e.g. phrasal_verb, conditional, past_tense", 
                        style: "width: 100%; max-width: 400px; padding: 6px;" %>
    <small style="color: #666; display: block; margin-top: 3px;">Tags will automatically be saved in lowercase.</small>
  </div>

  <%# Submit button %>
  <div>
    <%= form.submit %>
  </div>
<% end %>




<%# Place this at the very bottom of your _form.html.erb file %>
<script>
  // This function sets up the event listener for your button
  function setupAnswerToggler() {
    const btn = document.getElementById("add-answer-btn");
    if (!btn) return;

    btn.addEventListener("click", () => {
      // Find all hidden answer fields
      const hiddenFields = document.querySelectorAll(".answer-field-group[style*='display: none']");
      
      if (hiddenFields.length > 0) {
        // Reveal the first hidden field in the list
        hiddenFields[0].style.display = "block";
      }
      
      // If that was the last hidden field, hide the "+ Add" button entirely
      if (hiddenFields.length <= 1) {
        btn.style.display = "none";
      }
    });
  }

  // Runs on modern Rails dynamic page loads (Hotwire/Turbo)
  document.addEventListener("turbo:load", setupAnswerToggler);
  
  // Runs on classic full-page loads as a fallback
  document.addEventListener("DOMContentLoaded", setupAnswerToggler);
</script>