<%= form_with(model: question) do |form| %>
  <%# Throw any errors %>
  <% if question.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(question.errors.count, "error") %> prohibited this question from being saved:</h2>

      <ul>
        <% question.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Question main input %>
  <div>
    <%= form.label :main, style: "display: block" %>
    <%= form.text_field :main %>
  </div>

  <%# Answer input %>
  <div>
    <%= form.label :answer, style: "display: block" %>
    <%= form.text_field :answer %>
  </div>

  <%# Option A input %>
  <div>
    <%= form.label :a, style: "display: block" %>
    <%= form.text_field :answer %>
  </div>

  <%# Option B input %>
  <div>
    <%= form.label :b, style: "display: block" %>
    <%= form.text_field :b %>
  </div>

  <%# Option C input %>
  <div>
    <%= form.label :c, style: "display: block" %>
    <%= form.text_field :c %>
  </div>

  <%# Option B input %>
  <div>
    <%= form.label :d, style: "display: block" %>
    <%= form.text_field :d %>
  </div>

  <%# Submit button %>
  <div>
    <%= form.submit %>
  </div>
<% end %>
