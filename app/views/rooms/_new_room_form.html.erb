<%= form_with(model: @room, remote: true, class: "d-flex",
  data: {
            controller: "rooms",
            action: "turbo:submit-end->rooms#resetForm"
        }
) do |f| %>
  <%= f.text_field :name, class: "form-control", autocomplete: "off" %>
  <%= f.submit data: {disable_with: false} %>
<% end %>