<div id="chatroom_container" class="row bg-dark text-light">
  <div id="side_panel" class="col-md-4 col-sm-4">
    <li class="list-group-item d-flex align-items-center justify-content-between user_list_item">
      <%# Current User %>
      <div class="icon-container">
        <%= image_tag(current_user.chat_avatar, class: "chat_pfp") %>
        <%= turbo_stream_from "user_status" %>

        <div>
          <%= render "users/status", user: current_user %>
        </div>
      </div>

      <div class="ms-2 me-auto username">
        <%= current_user.name %>
      </div>
    </li>

    <%# List of Users %>
    <h4>Users</h4>
    <%= turbo_stream_from "users" %>
    <div id="users">
      <%= render @users %>
    </div>

    <%# List of Chat rooms %>
    <h4>Rooms</h4>
    <%= render "rooms/new_room_form" %>
    
    <%= turbo_stream_from "rooms" %>
    <div id="rooms">
      <%= render @rooms %>
    </div>
  </div>

  <div id="room-container" class="col-md-8 col-sm-8 bg-dark text-light">
    <% if @single_room %>
      <div id="single_room">
        <h4 class="text-center"><%= @user&.name || @single_room.name %></h4>

        <%= turbo_stream_from @single_room %>
        <div id="messages" data-controller="rooms">
          <%= render @messages %>
        </div>

        <%= render "messages/new_message_form" %>
      </div>
    <% end %>
  </div>
</div>
