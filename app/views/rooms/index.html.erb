<%= turbo_frame_tag "appearance_channel" %>
<div id="appearance_channel"></div>

<%= turbo_stream_from "user_status" %>

<%# Main structural layout view %>
<div id="chatroom_container" class="row bg-dark text-light g-0">
  <div id="side_panel" class="col-md-4 col-sm-4 px-3 pt-3">
    
    <%# Current User Status Card %>
    <ul class="list-group list-group-flush mb-3">
      <li class="list-group-item d-flex align-items-center justify-content-between user_list_item border-0">
        <div class="icon-container">
          <div class="chat_pfp d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
            style="background-color: #3498db; font-size: 18px; line-height: 1; user-select: none;">
            <%= current_user.avatar_initial %>
          </div>
          <div>
            <%= render "users/status", user: current_user %>
          </div>
        </div>
        <div class="ms-2 me-auto username fw-bold">
          <%= current_user.username %>
        </div>
      </li>
    </ul>

    <%# Active Users Queue %>
    <h5 class="text-muted small text-uppercase fw-bold mb-2">Users</h5>
    <%= turbo_stream_from "users" %>
    <div id="users" class="mb-4">
      <%= render @users %>
    </div>

    <%# Chat Rooms Queue %>
    <h5 class="text-muted small text-uppercase fw-bold mb-2">Rooms</h5>
    <%= render "rooms/new_room_form" %>
    
    <%= turbo_stream_from "rooms" %>
    <div id="rooms" class="mt-2">
      <%= render @rooms %>
    </div>
  </div>

  <%# Active Chat Window Panel Workspace %>
  <div id="room-container" class="col-md-8 col-sm-8 bg-dark text-light p-3 border-start border-secondary border-opacity-25">
    <% if @single_room %>
      <div id="single_room">
        <%# 1. Chat Header Title Line %>
        <h4 class="mb-3 pb-2 border-bottom border-secondary border-opacity-25"><%= @user&.username || @single_room.name %></h4>

        <%# 2. Dynamic Messages Container Scroll Box %>
        <%= turbo_stream_from @single_room %>
        <div id="messages" data-controller="rooms" data-rooms-target="scrollable" class="pe-2">
          <%= render @messages %>
        </div>

        <%# 3. ✅ FIXED: Input Form explicitly locked into place using a zero-shrink boundary wrap %>
        <div class="msg-form w-100 flex-shrink-0 mt-auto pt-3">
          <%= render "messages/new_message_form" %>
        </div>
      </div>
    <% else %>
      <div class="d-flex h-100 align-items-center justify-content-center text-muted small">
        💬 Select a room or user from the side panel to start chatting.
      </div>
    <% end %>
  </div>
</div>
