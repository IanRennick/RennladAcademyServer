<%# app/views/notifications/_notification.html.erb %>
<li id="<%= dom_id notification %>" class="list-group-item bg-transparent text-light border-secondary border-opacity-50 py-2 px-3 d-flex align-items-center justify-content-between gap-2" style="border-bottom: 1px solid rgba(255,255,255,0.08); <%= 'opacity: 0.5; background-color: rgba(0,0,0,0.1);' if notification.read_at.present? %>">
  
  <!-- Left Side: Clickable Event Source Deep-Link Area -->
  <%= link_to notification.params["url"].presence || root_path, class: "d-flex align-items-start gap-2 text-decoration-none text-light flex-grow-1", style: "min-width: 0;" do %>
    <div class="pt-1">
      <span class="d-inline-block rounded-circle <%= notification.read_at.present? ? 'bg-secondary bg-opacity-30' : 'bg-info' %>" style="width: 7px; height: 7px; box-shadow: <%= '0 0 6px #0dcaf0' unless notification.read_at.present? %>;"></span>
    </div>

    <div style="min-width: 0;">
      <p class="mb-0 text-white-50 small" style="line-height: 1.3; word-wrap: break-word; font-size: 0.85rem;">
        <strong class="text-white"><%= notification.actor.username %></strong> 
        <%= notification.params["message"] || "triggered an update" %>
      </p>
      <% if notification.params["text_snippet"].present? %>
        <small class="text-muted d-block text-truncate" style="font-size: 0.75rem; max-width: 200px;">
          "<%= notification.params["text_snippet"] %>"
        </small>
      <% end %>
      <small class="text-muted d-block" style="font-size: 0.68rem; margin-top: 1px;">
        ⏱️ <%= time_ago_in_words(notification.created_at) %> ago
      </small>
    </div>
  <% end %>

  <!-- Right Side: Asynchronous Single Item Dismissal Toggle Button Icon -->
  <div>
    <%= button_to toggle_read_notification_path(notification), 
                  method: :post,
                  class: "btn btn-link text-muted text-decoration-none p-1 border-0 rounded hover-danger-btn", 
                  title: notification.read_at.present? ? "Mark as unread" : "Dismiss alert",
                  style: "font-size: 1rem; line-height: 1; transition: all 0.15s;" do %>
      <%= notification.read_at.present? ? "↩️" : "×" %>
    <% end %>
  </div>
</li>

<style>
  .hover-danger-btn:hover { color: #dc3545 !important; background-color: rgba(220, 53, 69, 0.15); }
</style>