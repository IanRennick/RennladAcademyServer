<%# app/views/notifications/_notification.html.erb %>
<%# =========================================================================
    INDIVIDUAL NOTIFICATION LINE ITEM ROW PARTIAL
    - Automatically updates opacity parameters based on read_at states
    - Uses fully isolated button asynchronous forms to handle Turbo toggling
   ========================================================================= %>
<li id="<%= dom_id notification %>" class="list-group-item bg-transparent border-secondary border-opacity-20 py-2.5 px-3 d-flex align-items-center justify-content-between gap-2" 
    style="border-bottom: 1px solid rgba(255,255,255,0.06); <%= 'opacity: 0.45; background-color: rgba(0,0,0,0.2);' if notification.read_at.present? %>">
  
  <%# Left Interactive Target Area: Deep Link Redirection %>
  <%= link_to notification.params["url"].presence || root_path, class: "d-flex align-items-start gap-2 text-decoration-none flex-grow-1", style: "min-width: 0;" do %>
    
    <%# Visual Presence Status Sync Dot %>
    <div class="pt-1">
      <span class="d-inline-block rounded-circle <%= notification.read_at.present? ? 'bg-secondary bg-opacity-40' : 'bg-info' %>" 
            style="width: 7px; height: 7px; box-shadow: <%= '0 0 6px #0dcaf0' unless notification.read_at.present? %>;"></span>
    </div>

    <%# Text Context Strings Block %>
    <div style="min-width: 0;">
      <p class="mb-0 text-white-50 small" style="line-height: 1.35; font-size: 0.85rem;">
        <strong class="text-white fw-bold"><%= notification.actor.username %></strong> 
        <%= notification.params["message"] || "triggered a system event update" %>
      </p>
      
      <% if notification.params["text_snippet"].present? %>
        <small class="font-monospace d-block my-1 text-truncate" style="font-size: 0.76rem; max-width: 210px; color: #a0aec0;">
          "<%= notification.params["text_snippet"] %>"
        </small>
      <% end %>
      
      <%# UI Fix: Brightened relative timestamps color value %>
      <small class="d-block tracking-wide" style="font-size: 0.7rem; color: #cbd5e0; margin-top: 2px;">
        ⏱️ <%= time_ago_in_words(notification.created_at) %> ago
      </small>
    </div>
  <% end %>

  <%# Right Interactive Target Area: Single Item Drop Dismissal Forms %>
  <div class="ms-1">
    <%= button_to toggle_read_notification_path(notification), 
                  method: :post,
                  class: "btn btn-link p-1 border-0 rounded text-decoration-none tracking-normal #{notification.read_at.present? ? 'text-info hover-info-btn' : 'text-warning hover-danger-btn'}", 
                  title: notification.read_at.present? ? "Mark as unread" : "Dismiss alert",
                  style: "font-size: 1.05rem; line-height: 1; display: inline-block; transition: all 0.15s;" do %>
      <%= notification.read_at.present? ? "↩️" : "×" %>
    <% end %>
  </div>
</li>

<style>
  .hover-danger-btn:hover { color: #ff6b6b !important; background-color: rgba(220, 53, 69, 0.2); }
  .hover-info-btn:hover { color: #4fd1c5 !important; background-color: rgba(13, 202, 240, 0.15); }
</style>