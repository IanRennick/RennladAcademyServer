<!-- app/views/admin/dashboard/index.html.erb -->
<div class="container-fluid min-vh-100 bg-dark text-light p-4">
  
  <!-- Header Bar -->
  <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
    <div>
      <h2 class="fw-bold text-white mb-0">👑 Rennlad Academy Monitoring Station</h2>
      <p class="text-muted mb-0">Real-time student activity tracking, metrics analytics, and deep-links</p>
    </div>
    <span class="badge bg-primary px-3 py-2 fw-bold text-uppercase">System Mode: Live</span>
  </div>

  <!-- Metric Overview Cards Row -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card bg-black border-secondary text-light p-3">
        <div class="small text-uppercase text-muted fw-bold">Total Enrolled Body</div>
        <div class="display-5 fw-bold text-info"><%= @total_students %></div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-black border-secondary text-light p-3">
        <div class="small text-uppercase text-muted fw-bold">Active Sockets Online</div>
        <div class="display-5 fw-bold text-success"><%= @online_count %></div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-black border-secondary text-light p-3">
        <div class="small text-uppercase text-muted fw-bold">Idle State Users (Away)</div>
        <div class="display-5 fw-bold text-warning"><%= @away_count %></div>
      </div>
    </div>
  </div>

  <!-- Master Student Activity Directory Board -->
  <div class="card bg-black border-secondary">
    <div class="card-header bg-dark border-secondary py-3">
      <h5 class="mb-0 text-white fw-bold">💼 Active Student Directory Roll</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle mb-0">
        <thead>
          <tr class="text-muted border-secondary">
            <th scope="col" class="ps-4">Student</th>
            <th scope="col">Real-Time Presence</th>
            <th scope="col">Global Scoreboard (Elo)</th>
            <th scope="col">Last Server Connection</th>
            <th scope="col" class="text-end pe-4">Admin Controls / Links</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="border-secondary">
              <!-- Avatar & Name -->
              <td class="ps-4">
                <div class="d-flex align-items-center">
                  <div class="chat_pfp d-flex align-items-center justify-content-center text-white fw-bold shadow-sm me-3" 
                       style="background-color: #3498db; width: 40px; height: 40px; border-radius: 50%; font-size: 16px;">
                    <%= user.avatar_initial %>
                  </div>
                  <div>
                    <span class="fw-bold text-white"><%= user.username %></span>
                    <small class="d-block text-muted"><%= user.email %></small>
                  </div>
                </div>
              </td>
              
              <!-- Live Presence Badge -->
              <td>
                <% case user.status %>
                <% when "online" %>
                  <span class="badge bg-success text-white px-2 py-1"><i class="bi bi-circle-fill me-1"></i> Online</span>
                <% when "away" %>
                  <span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-clock-fill me-1"></i> Idle (Away)</span>
                <% else %>
                  <span class="badge bg-secondary text-light px-2 py-1">Offline</span>
                <% end %>
              </td>

              <!-- Rating -->
              <td>
                <span class="badge bg-info text-dark fw-bold px-2 py-1 font-monospace" style="font-size: 14px;">
                  ⚡ <%= user.rating %> Elo
                </span>
              </td>

              <!-- Last Seen Activity Timestamp -->
              <td class="text-muted small">
                <% if user.last_seen_at.present? %>
                  <!-- Display human-friendly relative time (e.g., "3 minutes ago" or "July 17, 14:32") -->
                  <%= time_ago_in_words(user.last_seen_at) %> ago 
                  <span class="d-block text-muted" style="font-size: 11px;"><%= user.last_seen_at.strftime("%b %d, %H:%M UTC") %></span>
                <% else %>
                  <span class="text-danger">Never Active</span>
                <% end %>
              </td>

              <!-- Control Link Anchors -->
              <td class="text-end pe-4">
                <div class="btn-group btn-group-sm">
                  <!-- Link to Open Their Personal History/Profile Subpage -->
                  <%= link_to "👁️ Profile", user_path(user), class: "btn btn-outline-info" if respond_to?(:user_path) %>
                  
                  <!-- Link to Drop Straight Into an Active Direct Chat Room With This Student -->
                  <%= link_to "💬 Chat", user_chat_path(user), class: "btn btn-outline-success" if respond_to?(:user_chat_path) %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
