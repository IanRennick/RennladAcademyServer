<%# app/views/dashboard/index.html.erb %>
<%# =========================================================================
    ADMINISTRATIVE CENTRAL MONITORING HUB
    - Pulls system metrics for students, channels, and operational metrics
    - Leverages modular sub-row view components to handle profile rows
   ========================================================================= %>
<div class="container-fluid bg-dark text-light p-4" style="background-color: #0f1115 !important;">
  
  <%# Header Status Control Bar %>
  <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
    <div>
      <h2 class="fw-bold text-white mb-0 tracking-wide">👑 Rennlad Academy Monitoring Hub</h2>
      <p class="text-white-50 small mb-0 mt-1">Real-time student asset logs, metrics analytics channels, and profile trackers</p>
    </div>
    <span class="badge bg-success bg-opacity-25 border border-success text-white px-3 py-2 fw-bold text-uppercase font-monospace" style="font-size: 0.75rem; letter-spacing: 0.5px;">
      System Status: Functional
    </span>
  </div>

  <%# Metric Overview Counters Row Grid %>
  <div class="row g-3 mb-4 font-sans">
    <%# Metric Box 1: Total Enrolled %>
    <div class="col-md-4">
      <div class="card bg-black bg-opacity-40 border border-secondary border-opacity-20 p-3 shadow-sm">
        <div class="small text-uppercase tracking-wider fw-bold text-white-50" style="font-size: 0.72rem;">Total Students</div>
        <div class="display-6 fw-bold text-info mt-1 font-monospace"><%= @total_students %></div>
      </div>
    </div>
    
    <%# Metric Box 2: Sockets Presence %>
    <div class="col-md-4">
      <div class="card bg-black bg-opacity-40 border border-secondary border-opacity-20 p-3 shadow-sm">
        <div class="small text-uppercase tracking-wider fw-bold text-white-50" style="font-size: 0.72rem;">Users Online</div>
        <div class="display-6 fw-bold text-success mt-1 font-monospace"><%= @online_count %></div>
      </div>
    </div>
    
    <%# Metric Box 3: Users Away %>
    <div class="col-md-4">
      <div class="card bg-black bg-opacity-40 border border-secondary border-opacity-20 p-3 shadow-sm">
        <div class="small text-uppercase tracking-wider fw-bold text-white-50" style="font-size: 0.72rem;">Users Away</div>
        <div class="display-6 fw-bold text-warning mt-1 font-monospace"><%= @away_count %></div>
      </div>
    </div>
  </div>

  <%# Master Student Directory Board Card Container %>
  <div class="card bg-black bg-opacity-30 border-secondary border-opacity-20 shadow-lg">
    <div class="card-header bg-dark bg-opacity-50 border-bottom border-secondary border-opacity-20 py-3">
      <h5 class="mb-0 text-white fw-bold d-flex align-items-center gap-2" style="font-size: 1.05rem;">
        <span>💼</span> Active Student Directory Roll
      </h5>
    </div>
    
    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
        <thead>
          <tr class="text-white-50 border-bottom border-secondary border-opacity-20" style="font-size: 0.8rem; background-color: rgba(0,0,0,0.15);">
            <th scope="col" class="ps-4 py-3 text-uppercase tracking-wider fw-semibold">Username</th>
            <th scope="col" class="py-3 text-uppercase tracking-wider fw-semibold">Status</th>
            <th scope="col" class="py-3 text-uppercase tracking-wider fw-semibold">Rating</th>
            <th scope="col" class="py-3 text-uppercase tracking-wider fw-semibold">Activity</th>
            <th scope="col" class="py-3 text-uppercase tracking-wider fw-semibold">Last Online</th>
            <th scope="col" class="text-end pe-4 py-3 text-uppercase tracking-wider fw-semibold">Links</th>
          </tr>
        </thead>
        <tbody>
          <% if @users.any? %>
            <% @users.each do |user| %>
              <%= render "dashboard/student_row", user: user %>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="text-center py-5 text-white-50 small font-monospace">
                ⚠️ No active student accounts mapped inside the repository.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>