<h1 class="text-center my-4"><%= pluralize(@questions.count, "Result") %></h1>

<div class="container">
  <div class="table-responsive">
    <table class="table table-dark table-striped align-middle">
      <thead>
        <tr>
          <th><%= sort_link(@query, :id, "ID", default_order: :asc) %></th>
          <th><%= sort_link(@query, :subtype, "Subtype") %></th>
          <th>Question Text (Main)</th>
          <th>First Answer</th>
          <th><%= sort_link(@query, :rating, "Rating") %></th>
          <th>Level</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% @questions.each do |question| %>
          <tr>
            <%# 1. ID column %>
            <td><small class="text-muted">#<%= question.id %></small></td>

            <%# 2. Subtype column %>
            <td><%= question.subtype.present? ? question.subtype.to_s.humanize : "None" %></td>

            <%# 3. Main column %>
            <td><%= link_to question.main, question, class: "text-decoration-none text-white fw-bold" %></td>
            
            <%# 4. First Answer column (safely gets the first entry from your JSON array) %>
            <td>
              <code class="text-warning fw-bold">
                <%= question.answers.first || "N/A" %>
              </code>
            </td>
            
            <%# 5. Rating column %>
            <td>
              <span class="badge bg-info text-dark" style="font-weight: bold;">
                <%= question.rating %> Elo
              </span>
            </td>

            <%# 6. Level column %>
            <td>
              <span class="badge bg-secondary">
                <%= question.level&.name || "N/A" %>
              </span>
            </td>

            <td>
              <%= link_to "View", question_path(question), class: "btn btn-sm btn-outline-light" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>