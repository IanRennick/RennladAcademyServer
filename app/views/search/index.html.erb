<h1 class="text-center"><%= pluralize(@questions.count, "Result") %></h1>

<div class="container">
    <table class= "table table-dark table-striped">
        <thead>
            <tr>
                <th><%= sort_link(@query, :main, "Main", default_order: :asc) %></th>
                <th><%= sort_link(@query, :answer, "Answer") %></th>
            </tr>
        </thead>

        <tbody>
            <% @questions.each do |question| %>
                <tr>
                    <td><%= link_to question.main, question %></td>
                    <td><%= question.answer %></td>
                </tr>
            <% end %>
        </tbody>
    </table>
</div>