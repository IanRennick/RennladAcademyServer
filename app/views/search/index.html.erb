<%# app/views/search/index.html.erb %>
<%# =========================================================================
    OMNI-SEARCH PERFORMANCE SEARCH CARD RESULTS MATRIX
    - Displays relational Ransack query results for student accounts and puzzle pools
    - Uses full-page dark layout consistency with zero contrast bugs
   ========================================================================= %>
<div class="container-fluid min-vh-100 bg-dark text-light p-4" style="background-color: #0f1115 !important;">

  <%# Search Master Dynamic Header %>
  <div class="text-center mb-5 mt-2">
    <h2 class="fw-bold text-white mb-1 tracking-wide font-sans">🔎 Search Results Matrix</h2>
    <span class="badge bg-secondary bg-opacity-15 border border-secondary text-white-50 font-monospace px-3 py-1.5" style="font-size: 0.85rem;">
      <%= pluralize(@questions.count, "Result Matching") %>
    </span>
  </div>

  <div class="container px-0 max-w-7xl font-sans">
    
    <%# =======================================================================
        SECTION A: OMNI-SEARCH MATCHING STUDENT ACCOUNTS DROPDOWN
       ======================================================================= %>
    <% if @users.any? %>
      <div class="mb-5">
        <h4 class="fw-bold mb-3 text-info tracking-wide d-flex align-items-center gap-2" style="font-size: 1.15rem;">
          <span>👥</span> Matching Student Profiles <span class="badge bg-info bg-opacity-15 border border-info text-info font-monospace py-0.5 px-2 rounded-pill small" style="font-size: 0.72rem;"><%= @users.count %></span>
        </h4>
        
        <div class="card bg-black bg-opacity-20 border border-secondary border-opacity-20 shadow-lg rounded overflow-hidden">
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; font-size: 0.88rem;">
              <thead>
                <tr class="text-white-50 border-bottom border-secondary border-opacity-20" style="font-size: 0.78rem; background-color: rgba(0,0,0,0.15);">
                  <th scope="col" class="ps-4 py-2.5 fw-semibold text-uppercase tracking-wider">Username</th>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Email Address</th>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Rating</th>
                  <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Review Queue</th>
                  <th scope="col" class="text-end pe-4 py-2.5 fw-semibold text-uppercase tracking-wider">Shortcuts</th>
                </tr>
              </thead>
              <tbody>
                <% @users.each do |user| %>
                  <tr class="border-bottom border-secondary border-opacity-10" style="transition: background-color 0.15s;">
                    <td class="ps-4 py-2.5"><strong class="text-white fw-bold"><%= user.username %></strong></td>
                    <td class="py-2.5"><span class="text-white-50 font-monospace" style="font-size: 0.8rem;"><%= user.email %></span></td>
                    <td class="py-2.5">
                      <span class="badge bg-primary bg-opacity-15 border border-primary text-info fw-bold font-monospace"><%= user.rating %> Elo</span>
                    </td>
                    <td class="py-2.5">
                      <% queue_count = user.user_histories.where(needs_review: true).count %>
                      <% if queue_count > 0 %>
                        <span class="badge bg-danger bg-opacity-15 border border-danger text-danger fw-bold font-monospace"><%= queue_count %> items pending</span>
                      <% else %>
                        <span class="badge bg-success bg-opacity-15 border border-success text-success fw-medium font-monospace">Clean Slate</span>
                      <% end %>
                    </td>
                    <td class="text-end pe-4 py-2.5">
                      <%= link_to user_path(user), class: "btn btn-xs btn-outline-info font-monospace fw-semibold px-2 py-1", style: "font-size: 0.74rem;" do %>
                        👁️ Profile
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <hr class="border-secondary border-opacity-20 my-5" />
    <% end %>

    <%# =======================================================================
        SECTION B: OMNI-SEARCH MATCHING CURRICULUM QUESTION DATA POOLS
       ======================================================================= %>
    <div>
      <h4 class="fw-bold mb-3 text-warning tracking-wide d-flex align-items-center gap-2" style="font-size: 1.15rem;">
        <span>📚</span> Matching Curriculum Questions
      </h4>
      
      <div class="card bg-black bg-opacity-20 border border-secondary border-opacity-20 shadow-lg rounded overflow-hidden">
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; font-size: 0.88rem;">
            <thead>
              <tr class="text-white-50 border-bottom border-secondary border-opacity-20" style="font-size: 0.78rem; background-color: rgba(0,0,0,0.15);">
                <th scope="col" class="ps-3 py-2.5 fw-semibold text-uppercase tracking-wider"><%= sort_link(@query, :id, "ID", default_order: :asc, class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider"><%= sort_link(@query, :subtype, "Subtype", class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Question Context</th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">First Answer Key</th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider"><%= sort_link(@query, :rating, "Rating", class: "text-white-50 text-decoration-none") %></th>
                <th scope="col" class="py-2.5 fw-semibold text-uppercase tracking-wider">Level</th>
                <th scope="col" class="text-end pe-4 py-2.5 fw-semibold text-uppercase tracking-wider">Shortcut</th>
              </tr>
            </thead>
            <tbody>
              <% if @questions.any? %>
                <% @questions.each do |question| %>
                  <tr class="border-bottom border-secondary border-opacity-10" style="transition: background-color 0.15s;">
                    <%# 1. ID Column %>
                    <td class="ps-3 py-2.5"><small class="text-white-50 font-monospace" style="font-size: 0.74rem;">#<%= question.id %></small></td>

                    <%# 2. Subtype Column %>
                    <td class="py-2.5 font-monospace text-light-50" style="font-size: 0.8rem;"><%= question.subtype.present? ? question.subtype.to_s.humanize : "General" %></td>

                    <%# 3. Main Text Column %>
                    <td class="py-2.5" style="max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      <%= link_to question.main, question_path(question), class: "text-decoration-none text-white fw-bold hover-info-link" %>
                    </td>
                    
                    <%# 4. First Answer column (safely gets the first entry from your JSON array) %>
                    <td class="py-2.5">
                      <code class="text-warning bg-warning bg-opacity-10 border border-warning border-opacity-10 px-2 py-0.5 rounded font-monospace" style="font-size: 0.78rem;">
                        "<%= question.answers.first || "N/A" %>"
                      </code>
                    </td>
                    
                    <%# 5. Rating column %>
                    <td class="py-2.5">
                      <span class="badge bg-info bg-opacity-25 border border-info text-white fw-bold font-monospace">
                        ⚡ <%= question.rating %> Elo
                      </span>
                    </td>

                    <%# 6. Level column %>
                    <td class="py-2.5">
                      <span class="badge bg-secondary bg-opacity-15 border border-secondary text-white-50 font-monospace small">
                        <%= question.level&.name || "N/A" %>
                      </span>
                    </td>

                    <%# 7. Actions Column %>
                    <td class="text-end pe-4 py-2.5">
                      <%= link_to question_path(question), class: "btn btn-xs btn-outline-light font-monospace fw-semibold px-2 py-1", style: "font-size: 0.74rem;" do %>
                        👁️ Dossier
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7" class="text-center py-5 text-white-50 small font-monospace">
                    📂 No curriculum question profiles found matching query metrics.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  .hover-info-link:hover { color: #0dcaf0 !important; }
</style>