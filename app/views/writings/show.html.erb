<div class="container">
  <%# Writing %>
  <%= render @writing %>

  <div>
    <%# Edit Writing Link %>
    <%= link_to "Edit this writing", edit_writing_path(@writing) %> |
    
    <%# Link to all writings %>
    <%= link_to "Back to writings", writings_path %>

    <%# Destroy Writing button %>
    <%= button_to "Destroy this writing", @writing, method: :delete %>
  </div>
</div>

<div class="container">
  <%# Comment Form %>
  <%= render "comments/writing_form", writing: @writing, comment: @writing.comments.build, submit_label: "Reply", commentable_type: "writing" %>

  <%# Comments %>
  <% @comments.each do |comment| %>
    <%= render "comments/writing_comment", writing: @writing, comment: comment %>
  <% end %>
</div>