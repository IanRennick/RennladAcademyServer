<div class="container">
  <%# Writing %>
  <%= render @writing %>

  <div>
    <%# Edit Writing Link %>
    <%= link_to "Edit this writing", edit_writing_path(@writing) %> |
    
    <%# Link to all writings %>
    <%= link_to "Back to writings", writings_path %>

    <%# Destroy Writing button %>
    <%= button_to "Destroy this writing", @writing, method: :delete %>
  </div>
</div>

<div class="container">
  <%# Render the central thread creation form %>
  <%= render "shared/comment_form", commentable: @question, comment: @question.comments.build, submit_label: "Post Comment" %>

  <%# Loop and print out the root comment tree threads %>
  <% @comments.each do |comment| %>
    <%= render "shared/comment", commentable: @question, comment: comment %>
  <% end %>
</div>