<%# app/views/user/_session_manager.html.erb %>

<% if current_user %>
  <!-- ✅ NEW: Real-time Notification Bell Dropdown Component -->
  <li class="nav-item dropdown me-2 position-relative align-self-center">
    <a class="nav-link position-relative px-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="notificationBellDropdown">
      <!-- Bootstrap Bell Icon (Uses an emoji visual anchor fallback here, or you can swap to bi-bell) -->
      <span style="font-size: 1.15rem; vertical-align: middle;">🔔</span>
      
      <!-- Dynamic Real-Time Unread Counter Badge -->
      <!-- If the user has unread notifications, it draws a vivid red indicator circle containing the count -->
      <% unread_count = current_user.notifications.unread.count %>
      <span id="nav-notification-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger <%= 'd-none' if unread_count == 0 %>" style="font-size: 0.65rem; padding: 0.25em 0.4em;">
        <%= unread_count %>
      </span>
    </a>

    <!-- Scrollable Notification Feed Dropdown Drawer Window Box -->
    <ul class="dropdown-menu dropdown-menu-end shadow-lg py-0 border-secondary" aria-labelledby="notificationBellDropdown" style="width: 320px; max-height: 400px; overflow-y: auto; font-size: 0.9rem; background-color: #1a1a1a;">
      <li class="p-2 border-bottom border-secondary bg-dark d-flex justify-content-between align-items-center">
        <span class="fw-bold text-white small text-uppercase tracking-wider">Alerts Notification Hub</span>
        
        <!-- ✅ UPGRADED: Button form tag ensures Rails captures the post action seamlessly -->
        <%= button_to mark_all_as_read_notifications_path, 
                      method: :post,
                      class: "btn btn-link text-info small text-decoration-none fw-semibold p-0 border-0", 
                      style: "font-size: 0.75rem;",
                      form: { class: "d-inline" } do %>
          Clear All
        <% end %>
      </li>

      <!-- ✅ TURBO REAL-TIME SOCKET STREAM ARCHITECTURE CONTAINER -->
      <!-- This wrapper listens on a user-specific secure ActionCable channel for live triggers -->
      <%= turbo_stream_from "global_notifications_#{current_user.id}" %>
      
      <div id="notifications_feed_container">
        <ul class="list-group list-group-flush bg-transparent mb-0" id="notifications_feed">
          <% recent_notifications = current_user.notifications.recent %>
          <% if recent_notifications.any? %>
            <% recent_notifications.each do |notification| %>
              <!-- We will create a beautiful single item row view partial next step -->
              <%= render "notifications/notification", notification: notification %>
            <% end %>
          <% else %>
            <!-- Default placeholder line shown when lists are clean -->
            <li class="list-group-item bg-transparent text-muted text-center py-4 small" id="empty-notification-placeholder">
              📂 Clean slate! No new notifications.
            </li>
          <% end %>
        </ul>
      </div>
    </ul>
  </li>

  <!-- Standard User Profile Management Dropdown Menu (Your existing code polished) -->
  <li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle fw-semibold text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
      <%= current_user.username %>
    </a>

    <ul class="dropdown-menu dropdown-menu-lg-end shadow border-secondary" style="background-color: #111111;">
      <!-- Updated Link: Deep link directly into your beautiful upgraded administrative command station -->
      <li><%= link_to "👑 Command Station", admin_dashboard_path, class: "dropdown-item text-light" if current_user.admin? %></li>
      <li><%= link_to "⚙️ Edit Account", edit_user_registration_path, class: "dropdown-item text-light" %></li>
      <li><hr class="dropdown-divider border-secondary"></li>
      <li><%= button_to "🚪 Sign Out", destroy_user_session_path, method: :delete, class: "dropdown-item text-danger" %></li>
    </ul>
  </li>

<% else %>
  <li class="nav-item">
    <%= link_to "Sign Up", new_user_registration_path, class: "nav-link text-white-50" %>
  </li>
  <li class="nav-item">
    <%= link_to "Log In", new_user_session_path, class: "nav-link text-white-50" %>
  </li>
<% end %>