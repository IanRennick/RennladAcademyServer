<%# app/views/layouts/_navbar.html.erb %>
<%# =========================================================================
    GLOBAL VERSION 2 NAVIGATION BAR COMPONENT
    - Inherits 'navbar-dark bg-dark' to match dark administrative views
    - Integrates automated Ransack query fields and user session widgets
   ========================================================================= %>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary border-opacity-50">
  <div class="container-fluid">
    
    <%# Primary App Branding Logo (Serves as dynamic Home link fallback) %>
    <%= link_to "Rennlad Academy", root_path, class: "navbar-brand fw-bold text-white tracking-wide" %>

    <%# Mobile Responsive Hamburger Dropdown Toggle %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <%# Collapsible Content Containers %>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <%# General Information Info Page Link %>
        <li class="nav-item">
           <%= link_to "Info", info_path, class: "nav-link px-3" %>
        </li>

        <%# Grammar & Vocabulary Central Puzzle Registry Library Link %>
        <li class="nav-item">
           <%= link_to "Grammar", questions_path, class: "nav-link px-3" %>
        </li>

        <%# Real-Time WebSocket Communication Chatroom Link %>
        <li class="nav-item">
           <%= link_to "Chat", rooms_path, class: "nav-link px-3" %>
        </li>
      </ul>

      <%# Right-Aligned Interaction Controls: Search Engine and User Dropdowns %>
      <ul class="navbar-nav align-items-center gap-1">
        <%= render "search/form" %>
        <%= render "user/session_manager" %>
      </ul>
    </div>
  </div>
</nav>